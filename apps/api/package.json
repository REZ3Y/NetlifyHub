{
  "name": "@netlifyhub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./telegram-quota-monitor": {
      "types": "./src/services/telegram-quota-monitor.service.ts",
      "import": "./dist/services/telegram-quota-monitor.service.js"
    },
    "./env": {
      "types": "./src/config/env.ts",
      "import": "./dist/config/env.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "create-admin": "tsx scripts/create-admin.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.0",
    "@netlifyhub/netlify-client": "workspace:*",
    "@netlifyhub/shared": "workspace:*",
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.10",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "fastify": "^5.2.1",
    "fetch-socks": "^1.3.3",
    "pino": "^9.6.0",
    "undici": "^8.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
