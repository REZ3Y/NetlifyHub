generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  passwordHash String
  role      Role      @default(VIEWER)
  /** IANA timezone for UI date formatting (e.g. Asia/Tehran). */
  timezone  String    @default("UTC")

  /** When true, outbound Netlify API calls from handlers use this proxy. */
  proxyEnabled Boolean @default(false)
  /** `http` (CONNECT) or `socks5` — used only if proxyEnabled. */
  proxyType    String?
  proxyHost    String?
  proxyPort    Int?
  proxyUsername String?
  /** Encrypted with TOKEN_ENCRYPTION_KEY (same as Netlify tokens). */
  proxyPasswordEncrypted String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  netlifyLinkedAccounts NetlifyLinkedAccount[]
  deployArtifacts PanelDeployArtifact[]
}

model NetlifyLinkedAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** Optional label chosen in the panel (not from Netlify). */
  label String?

  /** Netlify user `id` from GET /user. */
  netlifyId String
  uid       String
  fullName  String?
  avatarUrl String?
  email     String?
  affiliateId String?
  siteCount   Int     @default(0)
  netlifyCreatedAt String?
  netlifyLastLogin String?

  /** AES-256-GCM ciphertext (see `token-crypto`). */
  tokenEncrypted String

  /** When false, this linked account is ignored for outbound operations (UI only for now). */
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteNotes NetlifyLinkedSiteNote[]

  @@unique([userId, netlifyId])
  @@index([userId])
}

/** Panel-only title/note for a Netlify site under a linked account. */
model NetlifyLinkedSiteNote {
  id              String @id @default(cuid())
  linkedAccountId String
  linkedAccount   NetlifyLinkedAccount @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  netlifySiteId   String
  note            String @db.VarChar(512)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([linkedAccountId, netlifySiteId])
  @@index([linkedAccountId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

/** Zip artifacts stored in the panel for manual Netlify deploys. */
model PanelDeployArtifact {
  id               String @id @default(cuid())
  userId           String
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String @db.VarChar(128)
  originalFilename String @db.VarChar(255)
  /** Relative path under UPLOAD_STORAGE_PATH (e.g. `{userId}/{id}.zip`). */
  storagePath      String @db.VarChar(512)
  sizeBytes        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}
