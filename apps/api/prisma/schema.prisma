generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  passwordHash String
  role      Role      @default(VIEWER)
  /** IANA timezone for UI date formatting (e.g. Asia/Tehran). */
  timezone  String    @default("UTC")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  netlifyLinkedAccounts NetlifyLinkedAccount[]
}

model NetlifyLinkedAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** Optional label chosen in the panel (not from Netlify). */
  label String?

  /** Netlify user `id` from GET /user. */
  netlifyId String
  uid       String
  fullName  String?
  avatarUrl String?
  email     String?
  affiliateId String?
  siteCount   Int     @default(0)
  netlifyCreatedAt String?
  netlifyLastLogin String?

  /** AES-256-GCM ciphertext (see `token-crypto`). */
  tokenEncrypted String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, netlifyId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
