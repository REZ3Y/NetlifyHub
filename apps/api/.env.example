NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://netlifyhub:netlifyhub@localhost:5432/netlifyhub?schema=public
REDIS_URL=redis://localhost:6379
SESSION_TTL_DAYS=7
WEB_ORIGIN=http://localhost:5173
# COOKIE_SECURE=true
BCRYPT_ROUNDS=12
LOG_LEVEL=info
# Optional: serve Vue production build from this process (path to `apps/web/dist`)
# STATIC_WEB_ROOT=./apps/web/dist
# Required to link Netlify accounts: 32+ chars; used for AES-256-GCM at rest
# TOKEN_ENCRYPTION_KEY=
