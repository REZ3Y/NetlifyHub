# NetlifyHub — single environment file for local development (API, worker, web).
# Copy to `.env` in this directory (repo root):
#   cp .env.example .env

# --- API ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# Docker local stack uses host port 5433; native apt Postgres uses 5432 (installer sets this automatically).
DATABASE_URL=postgresql://netlifyhub:netlifyhub@127.0.0.1:5432/netlifyhub?schema=public
REDIS_URL=redis://localhost:6379
SESSION_TTL_DAYS=7
WEB_ORIGIN=http://localhost:5173
# COOKIE_SECURE=true
BCRYPT_ROUNDS=12
LOG_LEVEL=info
# Required to link Netlify accounts and store Telegram bot token (32+ chars).
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-string-at-least-32-chars
# Optional: serve Vue production build from the API process
# STATIC_WEB_ROOT=./apps/web/dist
# Optional: directory for deploy zip uploads (default: data/uploads under repo root)
# UPLOAD_STORAGE_PATH=./data/uploads

# --- Worker (Telegram quota checks) ---
# Cron pattern for BullMQ repeat job (default: every hour at minute 0).
# MUST be quoted when it contains spaces:
# Examples: "0 * * * *" hourly | "*/1 * * * *" every minute | "*/30 * * * *" every 30 min
TELEGRAM_QUOTA_CRON_PATTERN="0 * * * *"

# --- Web (Vite) ---
VITE_APP_TITLE=NetlifyHub
# Leave unset for local dev (Vite proxies /v1 to PORT). Set for production/Docker builds.
# VITE_API_BASE=http://localhost:3000

# --- Optional: first admin when database is empty (Docker / seed) ---
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=
