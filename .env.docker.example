# Docker Compose reads this repo-root `.env` (copy to `.env` next to docker-compose.yml).
# For local `pnpm dev`, use the same file — see `.env.example` for all variables.

WEB_ORIGIN=http://localhost:3000
VITE_APP_TITLE=NetlifyHub
SESSION_TTL_DAYS=7
TOKEN_ENCRYPTION_KEY=local-dev-token-encryption-key-min-32chars
TELEGRAM_QUOTA_CRON_PATTERN="0 * * * *"
LOG_LEVEL=info

# Optional first admin when database is empty
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
