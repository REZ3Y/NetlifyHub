# Docker Compose reads this file as repo-root `.env` (installer can create it interactively).
# Copy manually: cp .env.docker.example .env

WEB_ORIGIN=http://localhost:3000
VITE_APP_TITLE=NetlifyHub
SESSION_TTL_DAYS=7
# Must be 32+ characters (installer generates a random value).
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-string-at-least-32-chars
TELEGRAM_QUOTA_CRON_PATTERN="0 * * * *"
LOG_LEVEL=info
COOKIE_SECURE=false

# First admin when the database is empty (API entrypoint runs seed on startup).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-to-a-secure-password
