# Copy to `.env` next to `docker-compose.yml` for Docker deployments.
# Panel + API share port 3000 (SPA is served by Fastify from STATIC_WEB_ROOT).
WEB_ORIGIN=http://localhost:3000
VITE_APP_TITLE=NetlifyHub
SESSION_TTL_DAYS=7
# Optional first admin when database is empty (Docker / CI)
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
