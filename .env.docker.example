# Copy to `.env` next to `docker-compose.yml` for Docker deployments.
WEB_ORIGIN=http://localhost:8080
# Baked into the web image at build time (browser → API). Change if you publish API on another host/port.
VITE_API_BASE=http://localhost:3000
VITE_APP_TITLE=NetlifyHub
SESSION_TTL_DAYS=7
# Optional first admin when database is empty (Docker / CI)
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
