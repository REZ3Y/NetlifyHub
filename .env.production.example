# Personal backup template (gitignored copy: `.env.production`).
# On the server, copy contents into `.env` and run `docker compose up -d --build`.

WEB_ORIGIN=http://your-domain.example:3000
VITE_APP_TITLE=NetlifyHub
SESSION_TTL_DAYS=7
COOKIE_SECURE=false
LOG_LEVEL=info

TOKEN_ENCRYPTION_KEY=change-me-to-a-random-string-at-least-32-chars
TELEGRAM_QUOTA_CRON_PATTERN="0 * * * *"

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-to-a-secure-password

# Do NOT set DATABASE_URL or REDIS_URL — docker-compose.yml sets them for containers.
